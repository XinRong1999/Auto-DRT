#!/bin/sh
set -eu

APP_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
HTML_FILE="$APP_DIR/Resources/App/index.html"

if [ ! -f "$HTML_FILE" ]; then
  osascript -e 'display dialog "Auto DRT Analyzer files are missing." buttons {"OK"} default button "OK"' >/dev/null 2>&1 || true
  exit 1
fi

open "$HTML_FILE"
